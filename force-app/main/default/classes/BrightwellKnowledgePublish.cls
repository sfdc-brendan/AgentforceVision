/**
 * REST endpoint for the Brightwell "learning loop": creates a Knowledge article
 * from an AI-drafted payload and (optionally) publishes it. Called server-side
 * by the demo site after a photo diagnosis finds no matching Knowledge.
 *
 * POST /services/apexrest/brightwell/knowledge
 *   body: { title, summary, question, answerHtml, keywords, publish? }
 *
 * Includes a lightweight dedupe check so the loop doesn't create near-duplicate
 * articles for the same recurring problem.
 */
@RestResource(urlMapping='/brightwell/knowledge/*')
global with sharing class BrightwellKnowledgePublish {

    global class Req {
        public String title;
        public String summary;
        public String question;
        public String answerHtml;
        public String keywords;
        public Boolean publish;
    }

    @HttpPost
    global static void createArticle() {
        RestResponse res = RestContext.response;
        if (res == null) { res = new RestResponse(); RestContext.response = res; }
        res.addHeader('Content-Type', 'application/json');
        try {
            Req r = (Req) JSON.deserialize(RestContext.request.requestBody.toString(), Req.class);
            if (r == null || String.isBlank(r.title) || String.isBlank(r.answerHtml)) {
                respond(res, 400, new Map<String, Object>{ 'created' => false, 'error' => 'title and answerHtml are required' });
                return;
            }

            String dupTitle = findDuplicate(r.title, r.keywords);
            if (dupTitle != null) {
                respond(res, 200, new Map<String, Object>{ 'created' => false, 'reason' => 'duplicate', 'matchedTitle' => dupTitle });
                return;
            }

            Knowledge__kav kav = new Knowledge__kav();
            kav.Title = truncate(r.title, 255);
            kav.UrlName = uniqueSlug(r.title);
            kav.Language = 'en_US';
            if (String.isNotBlank(r.summary)) kav.Summary = truncate(r.summary, 1000);
            kav.FAQ_Answer__c = r.answerHtml;
            putIfField(kav, 'FAQ_Question__c', String.isBlank(r.question) ? r.title : r.question);
            putIfField(kav, 'FAQ_Internal_Comments__c', 'AI-generated by the Brightwell learning loop from a customer photo diagnosis.');
            Id rtId = faqRecordTypeId();
            if (rtId != null) kav.RecordTypeId = rtId;

            insert kav;

            Knowledge__kav created = [
                SELECT Id, KnowledgeArticleId, ArticleNumber, UrlName
                FROM Knowledge__kav WHERE Id = :kav.Id LIMIT 1
            ];

            // NOTE: This org does not expose the KbManagement Apex publish API, so
            // articles are created in Draft for one-click human publish/review.
            String status = 'Draft';

            respond(res, 201, new Map<String, Object>{
                'created' => true,
                'id' => created.Id,
                'articleNumber' => created.ArticleNumber,
                'urlName' => created.UrlName,
                'title' => kav.Title,
                'status' => status
            });
        } catch (Exception e) {
            respond(res, 500, new Map<String, Object>{ 'created' => false, 'error' => e.getMessage() });
        }
    }

    static void respond(RestResponse res, Integer code, Map<String, Object> body) {
        res.statusCode = code;
        res.responseBody = Blob.valueOf(JSON.serialize(body));
    }

    static String truncate(String s, Integer max) {
        return s == null ? null : (s.length() > max ? s.substring(0, max) : s);
    }

    static Id faqRecordTypeId() {
        for (RecordType rt : [
            SELECT Id FROM RecordType
            WHERE SobjectType = 'Knowledge__kav' AND DeveloperName = 'SDO_Knowledge_FAQ' LIMIT 1
        ]) {
            return rt.Id;
        }
        return null;
    }

    static String uniqueSlug(String title) {
        String base = (title == null ? 'article' : title).toLowerCase().replaceAll('[^a-z0-9]+', '-').replaceAll('(^-+|-+$)', '');
        if (String.isBlank(base)) base = 'article';
        if (base.length() > 200) base = base.substring(0, 200);
        String rnd = String.valueOf(Math.abs(Crypto.getRandomInteger()));
        if (rnd.length() > 6) rnd = rnd.substring(0, 6);
        return base + '-' + rnd;
    }

    static String findDuplicate(String title, String keywords) {
        String terms = String.isBlank(keywords) ? title : keywords;
        if (String.isBlank(terms)) return null;
        String clean = terms.replaceAll('[^a-zA-Z0-9 ]', ' ').trim();
        if (String.isBlank(clean)) return null;

        List<List<SObject>> results = Search.query(
            'FIND \'' + String.escapeSingleQuotes(clean) + '\' IN ALL FIELDS ' +
            'RETURNING Knowledge__kav(Title, Summary WHERE PublishStatus = \'Online\' AND Language = \'en_US\') LIMIT 5'
        );
        if (results.isEmpty() || results[0].isEmpty()) return null;

        Set<String> want = tokenize(title);
        if (want.isEmpty()) return null;
        Integer threshold = Math.max(2, (Integer) (want.size() * 0.6));
        for (SObject so : results[0]) {
            Knowledge__kav a = (Knowledge__kav) so;
            Set<String> have = tokenize(a.Title);
            Integer overlap = 0;
            for (String w : want) {
                if (have.contains(w)) overlap++;
            }
            if (overlap >= threshold) return a.Title;
        }
        return null;
    }

    static Set<String> tokenize(String s) {
        Set<String> out = new Set<String>();
        if (s == null) return out;
        for (String w : s.toLowerCase().replaceAll('[^a-z0-9 ]', ' ').split('\\s+')) {
            if (w.length() > 3) out.add(w);
        }
        return out;
    }

    static void putIfField(Knowledge__kav kav, String field, String val) {
        if (Knowledge__kav.SObjectType.getDescribe().fields.getMap().containsKey(field.toLowerCase())) {
            kav.put(field, val);
        }
    }
}
