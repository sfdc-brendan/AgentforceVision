# Copy to .env for local dev (the .env file is gitignored). On Heroku, set these
# with `heroku config:set KEY=value` instead.

# Required to enable the /admin dashboard. If unset, /admin login is disabled.
ADMIN_PASSWORD=change-me-to-a-strong-password

# Signs the admin session cookie and salts the stored IP hash. Set a long random
# value so admin sessions survive restarts. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Postgres connection string. Heroku Postgres sets this automatically once the
# addon is attached. If unset, the server uses an in-memory store that resets on
# restart (fine for local testing, not for real usage stats).
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# Port the server listens on. Heroku sets this automatically.
# PORT=8080
